{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch WebApi",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/dotnet/WebApi/bin/Debug/net10.0/WebApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/dotnet/WebApi",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:5000;"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "presentation": {
        "group": "fullstack",
        "order": 1
      }
    },
    {
      "type": "chrome",
      "name": "vben admin antd dev",
      "request": "launch",
      "url": "http://localhost:5666",
      "env": { "NODE_ENV": "development" },
      "sourceMaps": true,
      "webRoot": "${workspaceFolder}/src/vue/apps/web-antd",
      "preLaunchTask": "vue: dev",
      "presentation": {
        "group": "fullstack",
        "order": 2
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Launch WebApi", "vben admin antd dev"],
      "stopAll": true
    }
  ]
}
