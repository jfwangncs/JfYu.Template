{
  "$schema": "http://json.schemastore.org/template",
  "author": "jfwang",
  "classifications": ["Web", "WebAPI", "ASP.NET"],
  "identity": "JfYu.WebAPI.Template",
  "groupIdentity": "JfYu.WebAPI",
  "name": "JfYu Web API",
  "description": "A production-ready ASP.NET Core 10 Web API solution. Includes optional JWT authentication, role-based access control (RBAC), WeChat Mini Program login, OpenTelemetry tracing & metrics, Redis token store, and an xUnit test project.",
  "shortName": "JfYuWebApi",
  "icon": "icon.png",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "sourceName": "JfYu.WebApi.Template",
  "preferNameDirectory": false,
  "primaryOutputs": [
    {
      "path": "JfYu.WebApi.Template.slnx"
    }
  ],
  "symbols": {
    "JwtOption": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "Basic",
      "displayName": "JWT Authentication",
      "description": "Choose the JWT authentication strategy. 'None' disables auth entirely. 'Basic' uses in-memory token validation. 'Redis' stores tokens in Redis for distributed/multi-instance deployments.",
      "choices": [
        {
          "choice": "None",
          "displayName": "No Authentication",
          "description": "No JWT authentication"
        },
        {
          "choice": "Basic",
          "displayName": "JWT",
          "description": "JWT authentication without Redis"
        },
        {
          "choice": "Redis",
          "displayName": "JWT + Redis",
          "description": "JWT authentication with Redis token store (recommended for multi-instance)"
        }
      ]
    },
    "EnableJWT": {
      "type": "computed",
      "value": "(JwtOption != \"None\")"
    },
    "EnableJWTRedis": {
      "type": "computed",
      "value": "(JwtOption == \"Redis\")"
    },
    "EnableWeChat": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "displayName": "WeChat Mini Program Login",
      "description": "Add WeChat Mini Program OAuth login support via the JfYu.WeChat library."
    },
    "EnableTelemetry": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "displayName": "OpenTelemetry",
      "description": "Include OpenTelemetry for distributed tracing, metrics, and OTLP/Prometheus export."
    },
    "EnableUnitTest": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "displayName": "Unit Test Project",
      "description": "Add a companion xUnit test project with pre-wired service and controller tests."
    },
    "EnableRBAC": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "false",
      "displayName": "RBAC (Role-Based Access Control)",
      "description": "Include User / Role / Permission entities, EF Core migrations, and RBAC middleware. Requires JWT."
    }
  },
  "sources": [
    {
      "exclude": [
        "**/*.nuspec",
        "**/.template.config/**",
        "**/.vs/**",
        "**/bin/**",
        "**/obj/**"
      ],
      "modifiers": [
        {
          "condition": "(!EnableJWTRedis)",
          "exclude": [
            "JfYu.WebApi.Template/Constants/RedisKey.cs",
            "JfYu.WebApi.Template/Services/RedisCacheService.cs",
            "JfYu.WebApi.Template/Services/Interfaces/IRedisCacheService.cs",
            "JfYu.WebApi.Template/Controllers/RedisCacheController.cs",
            "JfYu.WebApi.Template/Model/RedisCache/RedisCacheModels.cs",
            "JfYu.WebApi.Template/Infrastructure/BlacklistMiddleware.cs"
          ]
        },
        {
          "condition": "(!EnableJWT)",
          "exclude": [
            "JfYu.WebApi.Template/Services/JwtService.cs",
            "JfYu.WebApi.Template/Services/Interfaces/IJwtService.cs",
            "JfYu.WebApi.Template/Options/JwtSettings.cs"
          ]
        },
        {
          "condition": "(!EnableUnitTest)",
          "exclude": ["JfYu.WebApi.Template.UnitTests/**"]
        },
        {
          "condition": "(!EnableJWT || !EnableRBAC)",
          "exclude": [
            "JfYu.WebApi.Template/Controllers/AuthController.cs",
            "JfYu.WebApi.Template/Controllers/RoleController.cs",
            "JfYu.WebApi.Template/Controllers/PermissionController.cs",
            "JfYu.WebApi.Template/Controllers/UserController.cs"
          ]
        },
        {
