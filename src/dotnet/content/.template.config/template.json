          "exclude": [
            "JfYu.WebApi.Template.UnitTests/Services/JwtServiceTests.cs",
            "JfYu.WebApi.Template.UnitTests/Controllers/AuthControllerTests.cs",
            "JfYu.WebApi.Template.UnitTests/Validations/LoginRequestValidationTests.cs"
          ]
        },
        {
